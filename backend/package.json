{
  "name": "backend-heavy-js-training-project",
  "version": "2.0.0",
  "description": "A production-style backend-heavy JavaScript REST API for senior backend training.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "relay": "node src/relay.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "test": "USE_IN_MEMORY=true vitest run",
    "test:watch": "USE_IN_MEMORY=true vitest",
    "lint": "eslint .",
    "seed:preview": "node scripts/seed-preview.js"
  },
  "keywords": ["backend", "express", "rest", "javascript", "architecture", "api", "postgres", "redis"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "prom-client": "^15.1.0",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "eslint": "^9.4.0",
    "supertest": "^7.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
